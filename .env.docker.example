# Global
TZ=Asia/Ho_Chi_Minh

# MySQL
MYSQL_ROOT_PASSWORD=change_me_strong_password

# Shared service secrets/config
OPENAI_API_KEY=dummy_key_for_local_dev
JWT_SECRET=012345678901234567890123456789123456789012345678901234567890abcd
JWT_EXPIRES_IN=24h
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_mail_username
SPRING_MAIL_PASSWORD=your_mail_password
SPRING_MAIL_PROTOCOL=smtp
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus
MERRIAM_API_KEY=your_merriam_api_key

# Node backend (TrinhHieu)
DB_USERNAME=root
DB_PASSWORD=change_me_strong_password
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# DaoKien frontend
VITE_ADMIN_TOKEN=
VITE_STUDENT_TOKEN=

# Ngan frontend
REACT_APP_API_DOMAIN=http://localhost:8081/
REACT_APP_AUTH_ORIGIN=http://localhost:5173
